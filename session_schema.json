{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunSession",
  "description": "One record per benchmarking or training run.",
  "type": "object",
  "required": ["session_id", "timestamp", "user", "stage", "config", "metrics", "runtime"],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "timestamp":  { "type": "string", "format": "date-time" },
    "user":       { "type": ["string", "null"] },
    "stage": {
      "type": "object",
      "required": ["baseline", "training"],
      "properties": {
        "baseline": { "type": "boolean" },
        "training": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "required": ["model", "dataset", "num_problems", "num_runs",
                   "batch_size", "max_new_tokens", "stop_sequences", "seed"],
      "properties": {
        "model":          { "type": "string" },
        "dataset":        { "type": "string" },
        "num_problems":   { "type": "integer", "minimum": 1 },
        "num_runs":       { "type": "integer", "minimum": 1 },
        "batch_size":     { "type": "integer", "minimum": 1 },
        "max_new_tokens": { "type": "integer", "minimum": 1 },
        "stop_sequences": { "type": "array", "items": { "type": "string" } },
        "seed":           { "type": "integer" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "test_pass_rate":              { "type": ["number", "null"] },
        "syntactic_correctness_ratio": { "type": ["number", "null"] },
        "token_throughput_per_sec":    { "type": ["number", "null"] }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["hostname", "num_gpus", "peak_gpu_memory_mb",
                   "gpu_utilization_pct", "total_duration_sec"],
      "properties": {
        "hostname":             { "type": "string" },
        "num_gpus":             { "type": "integer", "minimum": 0 },
        "peak_gpu_memory_mb":   { "type": ["number", "null"] },
        "gpu_utilization_pct":  { "type": ["number", "null"] },
        "total_duration_sec":   { "type": ["number", "null"] }
      }
    }
  }
}
