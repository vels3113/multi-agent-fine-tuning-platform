{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunSession",
  "description": "One record per run. config.baseline holds the baseline YAML; config.training holds the training YAML.",
  "type": "object",
  "required": ["session_id", "timestamp", "user", "stage", "config", "metrics", "runtime"],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "timestamp":  { "type": "string", "format": "date-time" },
    "user":       { "type": ["string", "null"] },
    "stage": {
      "type": "object",
      "required": ["baseline", "training"],
      "properties": {
        "baseline": { "type": "boolean" },
        "training": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "properties": {
        "baseline": {
          "type": "object",
          "required": ["model", "seed"],
          "properties": {
            "model": { "type": "string" },
            "seed":  { "type": "integer" }
          },
          "additionalProperties": true
        },
        "training": {
          "type": "object",
          "required": ["model", "seed"],
          "properties": {
            "model": { "type": "string" },
            "seed":  { "type": "integer" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "properties": {
        "test_pass_rate":              { "type": ["number", "null"] },
        "syntactic_correctness_ratio": { "type": ["number", "null"] },
        "token_throughput_per_sec":    { "type": ["number", "null"] },
        "num_problems":                { "type": ["integer", "null"] },
        "num_runs":                    { "type": ["integer", "null"] }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["hostname", "num_gpus", "peak_gpu_memory_mb",
                   "gpu_utilization_pct", "total_duration_sec", "latest_checkpoint",
                   "wandb_run_id"],
      "properties": {
        "hostname":             { "type": "string" },
        "num_gpus":             { "type": "integer", "minimum": 0 },
        "peak_gpu_memory_mb":   { "type": ["number", "null"] },
        "gpu_utilization_pct":  { "type": ["number", "null"] },
        "total_duration_sec":   { "type": ["number", "null"] },
        "latest_checkpoint":    { "type": ["string", "null"] },
        "wandb_run_id":         { "type": ["string", "null"] }
      }
    }
  }
}
